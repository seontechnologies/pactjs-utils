{
  "name": "@seontechnologies/pactjs-utils",
  "version": "1.1.0",
  "description": "A collection of utilities for Pact.js contract testing.",
  "workspaces": [
    "sample-app/*"
  ],
  "author": "Murat Ozcan",
  "license": "Apache-2.0",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "homepage": "https://github.com/seontechnologies/pactjs-utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seontechnologies/pactjs-utils.git"
  },
  "bugs": {
    "url": "https://github.com/seontechnologies/pactjs-utils/issues"
  },
  "keywords": [
    "pactjs",
    "utils"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start:sample-app": "npm-run-all --parallel start:backend start:frontend",
    "start:frontend": "cd sample-app/frontend && npm start",
    "start:backend": "cd sample-app/backend && npm start",
    "start:pact-server": "cd sample-app/backend && npm run start:pact",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || exit 0",
    "publish:local": "./scripts/publish.sh",
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm",
    "clean": "rm -rf dist",
    "build:types": "tsc -p tsconfig-build-types.json --declaration --declarationDir dist/types --emitDeclarationOnly",
    "build:cjs": "tsc -p tsconfig-cjs.json",
    "build:esm": "tsc -p tsconfig-esm.json",
    "prettier": "prettier --ignore-path .gitignore \"**/*.+(js|ts|json)\"",
    "fix:format": "npm run prettier -- --write",
    "validate": "npm-run-all --parallel typecheck lint test fix:format",
    "test:lib": "vitest run",
    "test:backend": "cd sample-app/backend && npm run test",
    "test:frontend": "cd sample-app/frontend && npm run vitest:run",
    "test:pact:consumer": "./scripts/check-pact-determinism.sh 'npm run test:pact:consumer:run' 3 ./pacts",
    "test:pact:consumer:run": "npm run test:pact:consumer:http && npm run test:pact:consumer:message",
    "test:pact:consumer:http": "vitest run --config pact/http/vitest.consumer.config.mts",
    "test:pact:consumer:message": "vitest run --config pact/message/vitest.consumer.config.mts",
    "test:pact:provider:local": "npm run test:pact:provider:local:contract && npm run test:pact:provider:local:message",
    "test:pact:provider:local:contract": "start-server-and-test start:pact-server http://localhost:3001 'vitest run --config pact/http/vitest.provider.config.mts'",
    "test:pact:provider:local:message": "vitest run --config pact/message/vitest.provider.config.mts",
    "test:pact:local": "npm run test:pact:consumer && npm run test:pact:provider:local",
    "publish:pact": ". ./scripts/env-setup.sh && ./scripts/publish-pact.sh",
    "test:pact:provider:remote": "npm run test:pact:provider:remote:contract && npm run test:pact:provider:remote:message",
    "test:pact:provider:remote:contract": ". ./scripts/env-setup.sh && start-server-and-test start:pact-server http://localhost:3001 'vitest run --config pact/http/vitest.provider.config.mts'",
    "test:pact:provider:remote:message": ". ./scripts/env-setup.sh && vitest run --config pact/message/vitest.provider.config.mts",
    "can:i:deploy:consumer": ". ./scripts/env-setup.sh && PACTICIPANT=SampleAppConsumer ./scripts/can-i-deploy.sh",
    "can:i:deploy:provider": ". ./scripts/env-setup.sh && PACTICIPANT=SampleMoviesAPI ./scripts/can-i-deploy.sh",
    "record:consumer:deployment": ". ./scripts/env-setup.sh && PACTICIPANT=SampleAppConsumer ./scripts/record-deployment.sh",
    "record:provider:deployment": ". ./scripts/env-setup.sh && PACTICIPANT=SampleMoviesAPI ./scripts/record-deployment.sh",
    "publish:provider:contract": ". ./scripts/env-setup.sh && ./scripts/publish-provider-contract.sh",
    "test": "npm-run-all --parallel test:lib test:backend test:frontend",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:clear-cache": "find . -name \"*.tsbuildinfo\" -delete && rm -rf node_modules/.cache/typescript",
    "lint": "eslint . --cache-location node_modules/.cache/eslint --fix",
    "docs:dev": "DOCS_BASE=/ vitepress dev docs",
    "docs:lint": "vitepress build docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "DOCS_BASE=/ vitepress preview docs"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --cache-location node_modules/.cache/eslint",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "peerDependencies": {
    "@pact-foundation/pact": ">=16.2.0",
    "zod": ">=3.0.0",
    "@asteasolutions/zod-to-openapi": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "@asteasolutions/zod-to-openapi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "9.9.0",
    "@pact-foundation/pact": "16.3.0",
    "@pact-foundation/pact-cli": "^16.1.7",
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "5.1.1",
    "@types/lodash": "4.17.24",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "dotenv": "16.6.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-implicit-dependencies": "1.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lodash": "4.18.1",
    "mermaid": "^11.14.0",
    "npm-run-all2": "7.0.2",
    "prettier": "3.8.3",
    "start-server-and-test": "^2.1.5",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "6.4.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.2.0",
    "zod": "4.3.6"
  },
  "dependencies": {
    "is-ci": "^4.1.0"
  }
}
