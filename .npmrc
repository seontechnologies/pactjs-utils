@seontechnologies:registry=https://registry.npmjs.org
legacy-peer-deps=true

# ===== SECURITY POLICIES =====
# Managed by the security team.

# Block git-based dependencies from re-enabling scripts (npm 11.10+)
allow-git=none

# Skip packages published less than 7 days ago
min-release-age=7

# Pin new packages to exact versions rather than semver ranges
save-exact=true
