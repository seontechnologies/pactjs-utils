# Pact Broker configuration (required for remote flow)
PACT_BROKER_BASE_URL=https://your-org.pactflow.io
PACT_BROKER_TOKEN=your_token_here

# CI metadata (automatically set by GitHub Actions)
# GITHUB_SHA=
# GITHUB_BRANCH=

# Breaking change flag (set to 'true' during coordinated breaking changes)
PACT_BREAKING_CHANGE=false

# Webhook payload URL (set automatically by PactFlow webhooks)
# PACT_PAYLOAD_URL=
